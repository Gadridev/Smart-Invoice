# Copy to .env and adjust. Vite only exposes variables prefixed with VITE_.
# Backend default port in this repo is 5000 (see backend/server.js).
#
# If you omit this file in dev, axios defaults to baseURL "/api" and vite.config.js
# proxies /api -> http://localhost:5000 (same machine).
VITE_API_URL=http://localhost:5000/api
